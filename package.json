    "@heroui/system": "^2.4.28",
    "@iconify/react": "^6.0.2",
    "@lobehub/icons": "^5.10.0",
    "@mingcute/react": "^1.4.1",
    "@monaco-editor/react": "^4.7.0",
    "@pierre/diffs": "^1.1.10",
    "@pierre/trees": "^1.0.0-beta.4",
    "@replit/codemirror-vim": "^6.3.0",
