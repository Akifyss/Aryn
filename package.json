    "chokidar": "^5.0.0",
    "diff": "^8.0.4",
    "docx-preview": "^0.3.7",
    "katex": "^0.16.45",
    "lodash.throttle": "^4.1.1",
    "lucide": "^1.8.0",
    "mermaid": "^11.14.0",
    "monaco-editor": "^0.55.1",
    "papaparse": "^5.5.3",
